{
  "name": "qrstorage_app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:css && npm run build:js",
    "build:css": "tailwindcss -i src/react-shell/styles.css -o dist/assets/react-shell.css --minify",
    "build:js": "esbuild src/react-shell/client.js --bundle --format=esm --outfile=dist/assets/react-shell.js",
    "prestart": "npm run build",
    "start": "node src/server.js",
    "test": "npm run test:node",
    "test:node": "node --test test/*.spec.js",
    "pretest:browser": "npm run build",
    "test:browser": "playwright test",
    "check": "npm run test:node && npm run test:browser"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "esbuild": "^0.25.3",
    "tailwindcss": "^3.4.17"
  }
}
